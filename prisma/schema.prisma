// QIAS — Prisma Schema
// QRIS Integrated Accounting System for Indonesian MSMEs

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// ─── ENUMS ───────────────────────────────────────────────

enum UserTier {
  PEMULA
  PRO
}

enum UserRole {
  USER
  ADMIN
}

enum PJSPProvider {
  GOPAY
  OVO
  DANA
  SHOPEEPAY
  LINKAJA
  QRIS_GENERIC
}

enum ConnectionStatus {
  ACTIVE
  INACTIVE
  ERROR
}

enum EntryType {
  DEBIT
  CREDIT
}

enum NotificationType {
  TRANSACTION
  ANOMALY
  REPORT_REMINDER
  BALANCE_WARNING
  SYSTEM
}

enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// ─── MODELS ──────────────────────────────────────────────

model User {
  id                 String            @id @default(cuid())
  name               String?
  email              String?           @unique
  emailVerified      DateTime?
  image              String?
  password           String?
  tier               UserTier          @default(PEMULA)
  role               UserRole          @default(USER)
  onboardingComplete Boolean           @default(false)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  accounts           Account[]
  sessions           Session[]
  business           Business?
  dashboardConfigs   DashboardConfig[]
  notifications      Notification[]
  anomalyAlerts      AnomalyAlert[]
  trialStatus        TrialStatus?

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model PasswordResetToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
  @@map("password_reset_tokens")
}


model Business {
  id        String   @id @default(cuid())
  name      String
  category  String
  city      String
  userId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  connections PJSPConnection[]

  @@map("businesses")
}

model PJSPConnection {
  id         String           @id @default(cuid())
  provider   PJSPProvider
  webhookUrl String           @unique
  hmacSecret String
  status     ConnectionStatus @default(INACTIVE)
  businessId String
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  business     Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([businessId])
  @@map("pjsp_connections")
}

model Transaction {
  id           String   @id @default(cuid())
  amount       Float
  referenceId  String   @unique
  pjspSource   String
  buyerInfo    String?
  metadata     String?  // JSON stored as string for SQLite compatibility
  connectionId String
  createdAt    DateTime @default(now())

  connection    PJSPConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  journalEntries JournalEntry[]

  @@index([connectionId])
  @@index([createdAt])
  @@map("transactions")
}

model JournalEntry {
  id            String    @id @default(cuid())
  type          EntryType
  account       String    // e.g., "Kas/Bank" or "Pendapatan"
  amount        Float
  description   String?
  transactionId String
  createdAt     DateTime  @default(now())

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([transactionId])
  @@index([createdAt])
  @@map("journal_entries")
}

model DashboardConfig {
  id        String   @id @default(cuid())
  name      String
  layout    String?  // JSON stored as string
  isDefault Boolean  @default(false)
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  widgets Widget[]

  @@index([userId])
  @@map("dashboard_configs")
}

model Widget {
  id                String @id @default(cuid())
  type              String // e.g., "revenue_total", "transaction_count", "heatmap"
  title             String
  position          String? // JSON: { x, y, w, h }
  config            String? // JSON: chart type, color, threshold, etc.
  dashboardConfigId String

  dashboardConfig DashboardConfig @relation(fields: [dashboardConfigId], references: [id], onDelete: Cascade)

  @@index([dashboardConfigId])
  @@map("widgets")
}

model Notification {
  id        String           @id @default(cuid())
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  metadata  String?          // JSON stored as string
  userId    String
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("notifications")
}

model AnomalyAlert {
  id          String        @id @default(cuid())
  type        String        // e.g., "revenue_spike", "revenue_drop"
  severity    AlertSeverity
  metric      String
  threshold   Float
  actualValue Float
  resolved    Boolean       @default(false)
  userId      String
  createdAt   DateTime      @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("anomaly_alerts")
}

model TrialStatus {
  id             String   @id @default(cuid())
  startDate      DateTime @default(now())
  endDate        DateTime
  isActive       Boolean  @default(true)
  convertedToLTD Boolean  @default(false)
  userId         String   @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("trial_statuses")
}
